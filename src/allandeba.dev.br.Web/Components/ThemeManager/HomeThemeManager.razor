@using allandeba.dev.br.Web.Common.Enums
@using allandeba.dev.br.Web.Services
@inject ThemeManagerService ThemeManagerService
@inject IJSRuntime JS
@implements IAsyncDisposable

@code {
    private IJSObjectReference? _module;
    private DotNetObjectReference<HomeThemeManager>? _dotNetRef;

    protected override void OnInitialized()
    {
        ThemeManagerService.OnThemeChanged += OnThemeChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _module = await JS.InvokeAsync<IJSObjectReference>("import", "./Components/ThemeManager/HomeThemeManager.razor.js");
        _dotNetRef = DotNetObjectReference.Create(this);
        var theme = await ThemeManagerService.GetCacheThemeAsync();
        await ApplyAsync(theme);
    }

    private async Task ApplyAsync(EThemeType theme)
    {
        if (_module is null) return;
        if (theme == EThemeType.System)
        {
            var isDark = await _module.InvokeAsync<bool>("getSystemPreference");
            await _module.InvokeVoidAsync("apply", isDark ? "dark" : "light");
            await _module.InvokeVoidAsync("watchSystem", _dotNetRef);
        }
        else
        {
            await _module.InvokeVoidAsync("stopWatching");
            await _module.InvokeVoidAsync("apply", theme == EThemeType.Dark ? "dark" : "light");
        }
    }

    [JSInvokable]
    public async Task OnSystemPreferenceChanged(bool isDark)
    {
        if (_module is not null)
            await _module.InvokeVoidAsync("apply", isDark ? "dark" : "light");
    }

    private void OnThemeChanged(EThemeType theme)
    {
        ApplyAsync(theme).ConfigureAwait(false);
    }

    public async ValueTask DisposeAsync()
    {
        ThemeManagerService.OnThemeChanged -= OnThemeChanged;
        if (_module is not null)
        {
            await _module.InvokeVoidAsync("stopWatching");
            await _module.DisposeAsync();
        }
        _dotNetRef?.Dispose();
    }
}
