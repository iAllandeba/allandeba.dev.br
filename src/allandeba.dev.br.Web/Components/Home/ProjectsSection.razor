@using allandeba.dev.br.Core.Models.Github

<section id="projects" class="terminal-section section-reveal" data-section="projects">
    <div class="terminal-section-inner">
        <div class="prompt-line anim">
            <span class="p-user">allandeba</span><span class="p-at">&#64;</span><span class="p-host">dev</span><span
            class="p-colon">:</span><span class="p-path">~/projetos</span><span
            class="p-sym">&nbsp;$&nbsp;</span><span class="p-cmd">git log --oneline --all</span>
        </div>

        @if (HasError)
        {
            <div class="git-error anim">
                <span class="git-err-sym">!</span>
                <span>failed to load repositories — check connection</span>
            </div>
        }
        else if (Projects is null)
        {
            @for (int i = 0; i < 3; i++)
            {
                <div class="git-entry git-skeleton">
                    <div class="git-entry-header">
                        <div class="shimmer" style="width:7ch;height:1rem"></div>
                        <div class="git-body">
                            <div class="shimmer" style="width:200px;height:1rem"></div>
                            <div class="shimmer" style="width:140px;height:0.75rem;margin-top:0.3rem"></div>
                        </div>
                    </div>
                </div>
            }
        }
        else if (Projects.Count == 0)
        {
            <div class="git-error anim">
                <span class="git-err-sym p-dim">~</span>
                <span>no repositories found</span>
            </div>
        }
        else
        {
            var idx = 0;
            @foreach (var project in Projects)
            {
                var hash = GetHash(project.Name);
                var shortDesc = project.Description?.Length > 80
                    ? project.Description[..80] + "..."
                    : project.Description ?? "";
                var delay = (idx++ * 0.08).ToString("F2", System.Globalization.CultureInfo.InvariantCulture);

                <div class="git-entry git-entry-anim" style="animation-delay: @(delay)s">
                    <div class="git-entry-header">
                        <span class="git-hash">@hash</span>
                        <div class="git-body">
                            <div class="git-title">@project.DisplayTitle</div>
                            @if (project.HasImpact)
                            {
                                <span class="git-impact">@project.Impact</span>
                            }
                            else if (!string.IsNullOrWhiteSpace(project.Description))
                            {
                                <span class="git-impact">@shortDesc</span>
                            }
                            @if (project.HasTechStack)
                            {
                                <span class="git-desc">@project.TechStackDisplay</span>
                            }
                            <div class="git-links">
                                <a href="@project.GithubUrl" target="_blank" class="git-link">
                                    <span class="git-link-icon">&#x2325;</span> Ver no GitHub
                                </a>
                                @if (project.HasWebsite)
                                {
                                    <a href="@project.Website" target="_blank" class="git-link live">
                                        <span class="git-link-icon">&#x25B6;</span> Abrir aplica&#231;&#227;o
                                    </a>
                                }
                            </div>
                            @if (project.HasDiff)
                            {
                                <div class="git-diff">
                                    <span class="d-info">diff --git a/@project.Name b/@project.Name</span>
                                    <span class="d-meta">--- Antes: @project.DiffBefore</span>
                                    @foreach (var line in project.DiffAdded)
                                    {
                                        <span class="d-add">+++ @line</span>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</section>


@code {
    [Parameter] public List<GithubProject>? Projects { get; set; }
    [Parameter] public bool HasError { get; set; }

    private static string GetHash(string name)
    {
        var h = Math.Abs(name.GetHashCode());
        return h.ToString("x").PadRight(7, '0')[..7];
    }
}
