<section id="contact" class="terminal-section section-reveal" data-section="contact" aria-label="Contato">
    <div class="terminal-section-inner">
        <div class="prompt-line anim">
            <span class="p-user">allandeba</span><span class="p-at">&#64;</span><span class="p-host">dev</span><span
            class="p-colon">:</span><span class="p-path">~/contato</span><span
            class="p-sym">&nbsp;$&nbsp;</span><span class="p-cmd">./contato.sh</span>
        </div>

        <div class="ct-output">
            <div class="ct-status-line anim">
                <span class="ct-arrow-g">&gt;</span>
                <span class="ct-arrow-d">&gt;</span>
                <span class="ct-status-text">Iniciando handshake...</span>
            </div>

            <div class="ct-channels anim">
                <div class="ct-channel">
                    <span class="ct-ch-key">email</span>
                    <a href="mailto:allandeba@icloud.com" class="ct-ch-val">allandeba&#64;icloud.com</a>
                    <span class="ct-ch-status">[ aguardando ]</span>
                </div>
                <div class="ct-channel">
                    <span class="ct-ch-key">linkedin</span>
                    <a href="https://www.linkedin.com/in/allan-debastiani/" target="_blank" rel="noopener noreferrer"
                       class="ct-ch-val">allan-debastiani</a>
                    <span class="ct-ch-status">[ aguardando ]</span>
                </div>
                <div class="ct-channel">
                    <span class="ct-ch-key">github</span>
                    <a href="https://github.com/allandeba" target="_blank" rel="noopener noreferrer"
                       class="ct-ch-val">allandeba</a>
                    <span class="ct-ch-status">[ aguardando ]</span>
                </div>
            </div>

            <div class="ct-progress-block anim">
                <div class="progress-bar-outer">
                    <div class="progress-bar-inner" id="progress-bar-inner"></div>
                </div>
                <div class="progress-text">
                    [&nbsp;<span id="progress-blocks">░░░░░░░░░░░░░░░░░░░░</span>&nbsp;]&nbsp;<span
                    id="progress-pct">0%</span>
                </div>
            </div>

            <div class="ct-result" id="contact-result" style="display:none">
                <span class="ct-arrow-g">&gt;</span>
                <span class="ct-result-text">Todos os canais online. Pronto para conectar.</span>
            </div>

            <div class="ct-chat-area">
                <button type="button" id="chat-btn" class="btn-t gold-btn" onclick="if(window.$chatwoot){window.$chatwoot.toggle()}else{window.location='mailto:allandeba@icloud.com'}">
                    ./enviar-mensagem
                </button>
            </div>
        </div>
    </div>
</section>

