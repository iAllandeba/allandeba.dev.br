<section id="experience" class="terminal-section section-reveal" data-section="experience">
    <div class="terminal-section-inner">
        <div class="prompt-line anim">
            <span class="p-user">allandeba</span><span class="p-at">&#64;</span><span class="p-host">dev</span><span
            class="p-colon">:</span><span class="p-path">~/experiencia</span><span
            class="p-sym">&nbsp;$&nbsp;</span><span class="p-cmd">cat </span><span
            class="p-arg">./experiencia.md</span>
        </div>

        @foreach (var job in _jobs)
        {
            <div class="exp-entry anim">
                <div class="exp-header">
                    <div>
                        <div class="exp-company">@job.Company</div>
                        <div class="exp-role">@job.Role</div>
                    </div>
                    <div class="exp-period">@job.Period</div>
                </div>
                <div class="exp-context">@job.Context</div>
                <ul class="exp-bullets">
                    @foreach (var bullet in job.Bullets)
                    {
                        <li>@((MarkupString)bullet)</li>
                    }
                </ul>
                <div class="exp-tags">
                    @foreach (var tag in job.Tags)
                    {
                        <span class="exp-tag">@tag</span>
                    }
                </div>
            </div>
        }
    </div>
</section>


@code {
    private record Job(string Company, string Role, string Period, string Context, string[] Bullets, string[] Tags);

    private Job[] _jobs =
    {
        new(
            Company: "Montreal Viagens",
            Role: "Full Stack Engineer",
