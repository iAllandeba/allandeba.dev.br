@layout HomeLayout
@page "/"
@using allandeba.dev.br.Core.Common.Constants
@using allandeba.dev.br.Core.Models.Github
@using allandeba.dev.br.Core.Requests.Github
@using allandeba.dev.br.Web.Components.Home

@inject IGithubHandler GithubHandler
@inject IJSRuntime JS
@implements IAsyncDisposable

<LoaderSection />
<HomeNavMenu />

<HeroSection />
<AboutSection />
<ExperienceSection />
<ProjectsSection Projects="_githubProjects" HasError="_hasError" />
<ContactSection />

<StatusBar />

@code {
    private List<GithubProject>? _githubProjects;
    private bool _hasError;
    private IJSObjectReference? _animModule;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var request = new GetGithubProjectRequest { User = OwnersInfo.GithubUser };
            var response = await GithubHandler.GetFavoriteProjectsAsync(request);
            if (response.IsSuccess)
                _githubProjects = response.Data?.GithubProjects;
            else
                _hasError = true;
        }
        catch
        {
            _hasError = true;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _animModule = await JS.InvokeAsync<IJSObjectReference>("import", "./Pages/Home.razor.js");
        await _animModule.InvokeVoidAsync("setBodyClass", "home-page", true);
        await _animModule.InvokeVoidAsync("init");
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_animModule is not null)
                await _animModule.InvokeVoidAsync("setBodyClass", "home-page", false);
        }
        catch { }
        if (_animModule is not null)
            await _animModule.DisposeAsync();
    }
}
